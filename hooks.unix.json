{
  "hooks": {
    "Stop": [{
      "matcher": "*",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" Stop", "timeout": 10, "async": true }]
    }],
    "Notification": [{
      "matcher": "(?i)task.?complet|done|finished|completed",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" Notification", "timeout": 10, "async": true }]
    }],
    "PermissionRequest": [{
      "matcher": "Bash|Write|Edit|Read",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" PermissionRequest", "timeout": 10, "async": true }]
    }],
    "Elicitation": [{
      "matcher": ".*",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" Elicitation", "timeout": 10, "async": true }]
    }],
    "TeammateIdle": [{
      "matcher": ".*",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" TeammateIdle", "timeout": 10, "async": true }]
    }],
    "PreToolUse": [{
      "matcher": "AskUserQuestion",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" Elicitation", "timeout": 10, "async": true }]
    }],
    "SubagentStop": [{
      "matcher": ".*",
      "hooks": [{ "type": "command", "command": "bash \"${CLAUDE_PLUGIN_ROOT}/play-sound.sh\" Notification", "timeout": 10, "async": true }]
    }]
  }
}
